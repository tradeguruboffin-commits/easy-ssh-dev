#!/usr/bin/env bash
set -Eeuo pipefail
IFS=$'\n\t'

# ==============================
# COLORS
# ==============================
GREEN="\033[1;32m"
YELLOW="\033[1;33m"
RED="\033[1;31m"
BLUE="\033[1;34m"
CYAN="\033[1;36m"
MAGENTA="\033[1;35m"
BOLD="\033[1m"
NC="\033[0m"

# ==============================
# CONFIG
# ==============================
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
SRC_DIR="$PROJECT_ROOT/src"

APP_NAME="sshx-dev"
SOURCE_FILE="$SRC_DIR/init.go"
OUTPUT_BIN="$PROJECT_ROOT/$APP_NAME"

# ==============================
# PRE BUILD
# ==============================
echo -e "${YELLOW}🧹 Cleaning old binary...${NC}"

if [[ -f "$OUTPUT_BIN" ]]; then
    rm -f "$OUTPUT_BIN"
    echo -e "${GREEN}✔ Old binary removed${NC}"
else
    echo -e "${CYAN}ℹ No previous binary found${NC}"
fi

# ==============================
# BUILD
# ==============================
echo -e "${BLUE}${BOLD}🔨 Building $APP_NAME...${NC}"
echo -e "${CYAN}📦 Flags: -trimpath -ldflags='-s -w' CGO_ENABLED=0${NC}"
echo -e "${MAGENTA}--------------------------------------${NC}"

if [[ ! -f "$SOURCE_FILE" ]]; then
    echo -e "${RED}❌ Source not found: $SOURCE_FILE${NC}"
    exit 1
fi

if CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o "$OUTPUT_BIN" "$SOURCE_FILE"; then
    chmod +x "$OUTPUT_BIN"
    SIZE=$(du -h "$OUTPUT_BIN" | cut -f1)
    BYTES=$(wc -c < "$OUTPUT_BIN")

    echo -e "${MAGENTA}--------------------------------------${NC}"
    echo -e "${GREEN}✅ Build complete!${NC}"
    echo -e "   📦 Output : ${BOLD}$OUTPUT_BIN${NC}"
    echo -e "   📊 Size   : $SIZE ($BYTES bytes)"
else
    echo -e "${MAGENTA}--------------------------------------${NC}"
    echo -e "${RED}❌ Build failed: $APP_NAME${NC}"
    exit 1
fi
