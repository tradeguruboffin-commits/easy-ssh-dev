#!/usr/bin/env bash
set -euo pipefail
IFS=$'\n\t'

APP_NAME="sshx-gui"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
GUI_DIR="$PROJECT_ROOT/gui"
BIN_DIR="$PROJECT_ROOT/bin"
VENV_DIR="$PROJECT_ROOT/.venv"

RED="\e[31m"; GREEN="\e[32m"; YELLOW="\e[33m"; BLUE="\e[34m"; NC="\e[0m"
log() { echo -e "${BLUE}➜${NC} $*"; }
ok()  { echo -e "${GREEN}✔${NC} $*"; }
warn(){ echo -e "${YELLOW}⚠${NC} $*"; }
err() { echo -e "${RED}✖${NC} $*"; }

DRY_RUN=false
VERBOSE=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --dry-run) DRY_RUN=true ;;
        --verbose) VERBOSE=true ;;
        -h|--help)
            echo "Usage: $0 [--dry-run] [--verbose]"
            exit 0
            ;;
        *)
            err "Unknown option: $1"
            exit 1
            ;;
    esac
    shift
done

run() {
    if [[ "$DRY_RUN" == true ]]; then
        echo -e "${YELLOW}[DRY-RUN]${NC} $*"
    else
        [[ "$VERBOSE" == true ]] && echo -e "${BLUE}[CMD]${NC} $*"
        "$@"
    fi
}

# -------------------------------------------------
# 📦 Python Detection
# -------------------------------------------------
echo "📦 Checking build dependencies..."
echo "🔎 Detecting usable Python interpreter..."

PYTHON_BIN=""

if command -v python3 >/dev/null 2>&1; then
  if python3 -c 'import sys; exit(0 if sys.version_info >= (3,8) else 1)' 2>/dev/null; then
    if python3 -m venv --help >/dev/null 2>&1; then
      PYTHON_BIN="python3"
    fi
  fi
fi

if [[ -z "$PYTHON_BIN" ]] && command -v python >/dev/null 2>&1; then
  if python -c 'import sys; exit(0 if sys.version_info >= (3,8) else 1)' 2>/dev/null; then
    if python -m venv --help >/dev/null 2>&1; then
      PYTHON_BIN="python"
    fi
  fi
fi

if [[ -z "$PYTHON_BIN" ]]; then
  err "No usable Python 3.8+ with venv found."
  exit 1
fi

ok "Using $PYTHON_BIN ($($PYTHON_BIN --version))"
ok "All required dependencies found."

# -------------------------------------------------
# 🖥 OS Detection
# -------------------------------------------------
OS=""
SUDO=""
ARCH=$(uname -m)

case "$ARCH" in
    x86_64)        ARCH_TAG="x86_64" ;;
    aarch64|arm64) ARCH_TAG="arm64"  ;;
    i?86)          ARCH_TAG="x86"    ;;
    *)             ARCH_TAG="$ARCH"  ;;
esac

log "Detected architecture: $ARCH_TAG"

if [[ -n "${TERMUX_VERSION:-}" ]]; then
    OS="termux"
elif command -v apt    >/dev/null 2>&1; then OS="debian"
elif command -v dnf    >/dev/null 2>&1; then OS="fedora"
elif command -v pacman >/dev/null 2>&1; then OS="arch"
elif command -v apk    >/dev/null 2>&1; then OS="alpine"
else
    err "Unsupported OS."
    exit 1
fi

[[ "$EUID" -ne 0 && -x "$(command -v sudo)" ]] && SUDO="sudo"
log "Detected OS: $OS"

# -------------------------------------------------
# GTK + VTE Check
# -------------------------------------------------
check_gtk_vte() {
    local MISSING=()
    for lib in gtk+-3.0 vte-2.91; do
        if ! pkg-config --exists "$lib" 2>/dev/null; then
            warn "$lib not found!"
            MISSING+=("$lib")
        else
            ok "$lib found"
        fi
    done

    if [[ ${#MISSING[@]} -gt 0 ]]; then
        log "Installing missing GTK/VTE packages..."
        case "$OS" in
            debian) run $SUDO apt install -y libgtk-3-dev libvte-2.91-dev ;;
            fedora) run $SUDO dnf install -y gtk3-devel vte291-devel ;;
            arch)   run $SUDO pacman -Syu --noconfirm gtk3 vte3 ;;
            alpine) run $SUDO apk add gtk+3.0-dev vte-dev ;;
            termux) run pkg install -y gtk3 vte ;;
        esac
    fi
}

check_gtk_vte

# -------------------------------------------------
# 🐍 Virtual Environment
# -------------------------------------------------
run rm -rf "$VENV_DIR"
run $PYTHON_BIN -m venv --system-site-packages "$VENV_DIR"

if [[ "$DRY_RUN" == false ]]; then
    source "$VENV_DIR/bin/activate"
fi

run pip install --upgrade pip setuptools wheel
run pip install --force-reinstall pyinstaller==6.13.0

# Link system site-packages (for gi/GTK access inside venv)
if [[ "$DRY_RUN" == false ]]; then
    SITE_PACKAGES="$VENV_DIR/lib/$($PYTHON_BIN -c 'import sys; print(f"python{sys.version_info.major}.{sys.version_info.minor}")')/site-packages"
    mkdir -p "$SITE_PACKAGES"
    SYS_PYTHON=$($PYTHON_BIN -c "import sysconfig; print(sysconfig.get_paths()['purelib'])")
    echo "$SYS_PYTHON" > "$SITE_PACKAGES/system.pth"
fi

# -------------------------------------------------
# 🧹 Clean old builds
# -------------------------------------------------
log "Cleaning old builds..."
run rm -rf "$GUI_DIR/build" "$GUI_DIR/dist" "$GUI_DIR/$APP_NAME.spec" "$GUI_DIR/$APP_NAME" "$GUI_DIR/_internal"
cd "$GUI_DIR"

# -------------------------------------------------
# 🚀 Build GUI
# -------------------------------------------------
log "Building GUI (PyInstaller)..."
run pyinstaller \
  --noconfirm \
  --onedir \
  --name "$APP_NAME" \
  --clean \
  --noupx \
  --hidden-import=gi \
  --hidden-import=gi.repository.Gtk \
  --hidden-import=gi.repository.Vte \
  --collect-all gi \
  --add-data "$BIN_DIR:bin" \
  easy-ssh-gui.py

# -------------------------------------------------
# 📦 Move binaries to gui/
# -------------------------------------------------
log "Moving GUI binaries..."

if [[ "$DRY_RUN" == false ]]; then
  if [[ -f "$GUI_DIR/dist/$APP_NAME/$APP_NAME" ]]; then
    run mv -f "$GUI_DIR/dist/$APP_NAME/$APP_NAME"  "$GUI_DIR/"
    [[ -d "$GUI_DIR/dist/$APP_NAME/_internal" ]] && \
      run mv -f "$GUI_DIR/dist/$APP_NAME/_internal" "$GUI_DIR/"
  else
    err "GUI build failed — binary missing."
    exit 1
  fi
else
  echo "➜ mv -f $GUI_DIR/dist/$APP_NAME/$APP_NAME $GUI_DIR/"
  echo "➜ mv -f $GUI_DIR/dist/$APP_NAME/_internal $GUI_DIR/"
fi

run rm -rf "$GUI_DIR/dist" "$GUI_DIR/build" "$GUI_DIR/$APP_NAME.spec"

ok "Build complete → gui/$APP_NAME"

# -------------------------------------------------
# 🧼 Cleanup venv
# -------------------------------------------------
log "Cleaning virtual environment..."
deactivate 2>/dev/null || true
run rm -rf "$VENV_DIR"

ok "All done successfully 🎉"
