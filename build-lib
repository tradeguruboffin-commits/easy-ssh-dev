#!/usr/bin/env bash
# build-lib — Unified Go Builder (Clean Size Version)

set -Eeuo pipefail

# ==============================
# COLORS
# ==============================
GREEN="\033[1;32m"
YELLOW="\033[1;33m"
RED="\033[1;31m"
BLUE="\033[1;34m"
CYAN="\033[1;36m"
MAGENTA="\033[1;35m"
NC="\033[0m"

OUTPUT_DIR="./lib"
mkdir -p "$OUTPUT_DIR"

# List of source files
SOURCES=(
    "git-auth.go"
    "sshx-cpy.go"
    "sshx-reset.go"
)

echo -e "${BLUE}🚀 Starting lib/* binaries build...${NC}"
echo -e "${CYAN}📦 Using -trimpath -ldflags='-s -w'${NC}"
echo -e "${MAGENTA}--------------------------------------${NC}"

for SOURCE_FILE in "${SOURCES[@]}"; do

    if [[ ! -f "$SOURCE_FILE" ]]; then
        echo -e "${YELLOW}⚠ Skipping $SOURCE_FILE (not found)${NC}"
        continue
    fi

    BINARY_NAME="${SOURCE_FILE%.go}"
    OUTPUT_PATH="$OUTPUT_DIR/$BINARY_NAME"

    echo ""
    echo -e "${BLUE}🔨 Building $BINARY_NAME...${NC}"

    if CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o "$OUTPUT_PATH" "$SOURCE_FILE"; then
        SIZE=$(wc -c < "$OUTPUT_PATH")
        echo -e "${GREEN}✅ Built: $OUTPUT_PATH${NC}"
        echo -e "${CYAN}📊 Size:${NC} ${SIZE} bytes"
    else
        echo -e "${RED}❌ Build failed for $BINARY_NAME${NC}"
        exit 1
    fi

done

echo ""
echo -e "${MAGENTA}--------------------------------------${NC}"
echo -e "${GREEN}⚙️ lib/* binaries created successfully! 🆗${NC}"
