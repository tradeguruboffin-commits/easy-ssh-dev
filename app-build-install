#!/usr/bin/env bash
# =========================================================
# easy-ssh-dev — Portable Clean Build Script
# Author: Sumit
# =========================================================

set -Eeuo pipefail

trap 'rc=$?; echo "❌ Error on line $LINENO. Exit code: $rc"; exit $rc' ERR

IFS=$'\n\t'

# ---------------- Safe Argument Parser ----------------

DRY_RUN=false
CLI_ONLY=false

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run)
        DRY_RUN=true
        shift
        ;;
      --cli)
        CLI_ONLY=true
        shift
        ;;
      --help|-h)
        echo "Usage: $0 [--dry-run] [--cli]"
        echo "  --dry-run   No changes will be made"
        echo "  --cli       Skip GUI build"
        exit 0
        ;;
      --*=*)
        echo "❌ Unknown option: ${1%%=*}"
        echo "Use --help to see available options."
        exit 1
        ;;
      --*)
        echo "❌ Unknown option: $1"
        echo "Use --help to see available options."
        exit 1
        ;;
      -*)
        echo "❌ Unknown option: $1"
        exit 1
        ;;
      *)
        echo "❌ Unexpected argument: $1"
        exit 1
        ;;
    esac
  done
}

parse_args "$@"

if [[ "$DRY_RUN" == true ]]; then
  echo "🧪 Running in DRY RUN mode — no changes will be made."
fi

if [[ "$CLI_ONLY" == true ]]; then
  echo "⚙️  CLI only mode — GUI build will be skipped."
fi

run() {
  echo "➜ $*"
  if [[ "$DRY_RUN" != true ]]; then
    "$@"
  fi
}

# ---------------- Paths ----------------

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
GUI="$PROJECT_ROOT/gui"
LIB="$PROJECT_ROOT/lib"
BIN="$PROJECT_ROOT/bin"

echo "📁 Project root: $PROJECT_ROOT"

# ---------------- Dependency Check ----------------

need() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "❌ $1 not installed."
    exit 1
  }
}

echo "📦 Checking build dependencies..."

need go

echo "✅ required dependencies found."

# ---------------- Clean Old Binaries ----------------

echo "🧹 Removing old binaries..."

run mkdir -p "$BIN"
run mkdir -p "$LIB"

if [[ "$CLI_ONLY" == false ]]; then
  run rm -f "$BIN/sshx" \
             "$PROJECT_ROOT/sshx-dev" \
             "$BIN/sshx-key" \
             "$BIN/scpx" \
             "$GUI/sshx-gui" \
             "$LIB/git-auth" \
             "$LIB/sshx-cpy" \
             "$LIB/sshx-reset"
  run rm -rf "$GUI/_internal"
else
  run rm -f "$BIN/sshx" \
             "$PROJECT_ROOT/sshx-dev" \
             "$BIN/sshx-key" \
             "$BIN/scpx" \
             "$LIB/git-auth" \
             "$LIB/sshx-cpy" \
             "$LIB/sshx-reset"
fi

# ---------------- Build Go Binaries ----------------

echo "🚀 Building Go binaries..."

cd "$PROJECT_ROOT"
run ./build-bin
run ./build-lib
run ./build-init

# ---------------- GUI Build ----------------

if [[ "$CLI_ONLY" == false ]]; then
  echo "Starting GUI Building..."
  run ./build-gui
  cd "$PROJECT_ROOT"
else
  echo "⏭ Skipping GUI build (--cli mode)"
fi

# ---------------- Artifacts ----------------

echo ""
echo "🔍 Verifying build artifacts..."

common_artifacts=(
  "$BIN/sshx"
  "$BIN/sshx-key"
  "$BIN/scpx"
  "$LIB/git-auth"
  "$LIB/sshx-cpy"
  "$LIB/sshx-reset"
  "$PROJECT_ROOT/sshx-dev"
)

if [[ "$CLI_ONLY" == false ]]; then
  artifacts=("${common_artifacts[@]}" "$GUI/sshx-gui")
else
  artifacts=("${common_artifacts[@]}")
fi

if [[ "$DRY_RUN" == false ]]; then
  for file in "${artifacts[@]}"; do
    if [[ ! -f "$file" ]]; then
      echo "❌ Missing artifact: $file"
      exit 1
    fi
    if [[ ! -s "$file" ]]; then
      echo "❌ Artifact exists but empty: $file"
      exit 1
    fi
  done
  echo "✅ All build artifacts verified."
else
  printf "➜ verify %s\n" "${artifacts[@]}"
fi

echo ""
echo "📦 Build Summary:"
printf "  ✔ %s\n" "${artifacts[@]}"
echo ""

for f in "${artifacts[@]}"; do
  run chmod +x "$f"
done

cd "$PROJECT_ROOT"

if [[ "$DRY_RUN" == false ]]; then
  if [[ -x "$PROJECT_ROOT/sshx-dev" ]]; then
    run "$PROJECT_ROOT/sshx-dev" install
  else
    echo "❌ sshx-dev missing, cannot install."
    exit 1
  fi
else
  echo "➜ $PROJECT_ROOT/sshx-dev install"
fi

echo ""
if [[ "$CLI_ONLY" == false ]]; then
  echo "✅ SSHX CLI + GUI installed successfully!"
else
  echo "✅ SSHX CLI installed successfully!"
fi
echo ""
