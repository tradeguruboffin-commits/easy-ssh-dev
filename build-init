#!/usr/bin/env bash
set -euo pipefail

APP_NAME="sshx-dev"
SOURCE_FILE="init.go"

OUTPUT_BIN="$APP_NAME"

echo "🔨 Building $APP_NAME..."

# Build command
CGO_ENABLED=0 go build -ldflags="-s -w" -o "$OUTPUT_BIN" "$SOURCE_FILE"
chmod +x "$OUTPUT_BIN"

echo "✅ Build complete!"
echo "📦 Output: $OUTPUT_BIN"
